# Public URLs — desktop phase: use the host machine's LAN IP; cloud: use your domain
# The UI proxies /api to the backend container, so PUBLIC_API_URL should match
# PUBLIC_APP_URL (same host/port). Port 8000 remains for direct ingest/CV access.
PUBLIC_APP_URL=http://192.168.1.50:3000
PUBLIC_API_URL=http://192.168.1.50:3000

# Database
POSTGRES_USER=vvt
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vvt
DATABASE_URL=postgresql+psycopg://vvt:change-me@db:5432/vvt

# API
API_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=change-me-long-random
INGEST_API_KEY=change-me-ingest-key
CORS_ORIGINS=http://192.168.1.50:3000,http://localhost:3000

# Images
IMAGE_STORAGE_PATH=/data/images
IMAGE_STORAGE_BACKEND=local
IMAGE_FETCH_TIMEOUT_SECONDS=10
IMAGE_MAX_BYTES=5000000
IMAGE_SIGNED_URL_EXPIRE_MINUTES=60
# Optional comma-separated URL prefixes; empty allows all http(s) ingest URLs
CV_IMAGE_URL_ALLOWLIST=

# App
DISPLAY_TIMEZONE=Asia/Manila
LOG_LEVEL=INFO

# Dev seed (optional; used by `make seed` and `python -m app.scripts.create_admin`)
BOOTSTRAP_ADMIN_PASSWORD=admin

# Development only — skip JWT checks for admin routes (default false)
DEV_AUTH_BYPASS=false
